NEXT_PUBLIC_APP_NAME="Facility Expense Control"

# Production secret source. When set, server code reads sensitive values from Azure Key Vault.
AZURE_KEY_VAULT_URL="https://fm-expense-kv.vault.azure.net/"

# Required on Vercel or any non-Azure host so DefaultAzureCredential can access Key Vault.
# In Azure App Service/Container Apps, prefer Managed Identity instead of these values.
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-app-registration-client-id"
AZURE_CLIENT_SECRET="your-app-registration-client-secret"

# Local development fallback only. Do not set these in production when Key Vault is configured.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=..."

APP_AUTH_MODE="development"
DEV_USER_ID="emp-claimant-001"
DEV_USER_ROLE="Claimant"

# In APP_AUTH_MODE=test, redirect all email notifications to a verified test inbox.
NOTIFICATION_TEST_RECIPIENT="your-verified-test-email@example.com"
